{
  "name": "tempest-react-sdk",
  "version": "0.6.0",
  "description": "SDK público da Tempest com componentes, hooks e integrações para projetos React.",
  "type": "module",
  "license": "MIT",
  "author": "Mauricio Benjamin <mauriciobenjamin700@gmail.com>",
  "homepage": "https://github.com/mauriciobenjamin700/tempest-react-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauriciobenjamin700/tempest-react-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mauriciobenjamin700/tempest-react-sdk/issues"
  },
  "keywords": [
    "react",
    "sdk",
    "tempest",
    "ui",
    "components",
    "hooks"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/tempest-react-sdk.cjs",
  "module": "./dist/tempest-react-sdk.js",
  "types": "./dist/tempest-react-sdk.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/tempest-react-sdk.d.ts",
      "import": "./dist/tempest-react-sdk.js",
      "require": "./dist/tempest-react-sdk.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b tsconfig.build.json && vite build",
    "typecheck": "tsc -b tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "size": "size-limit",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test:run && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "dexie": "^4.4.2",
    "lucide-react": ">=0.400.0",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^7.18.0",
    "zod": "^3.23.0 || ^4.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^4.0.0 || ^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@tanstack/react-query": "^5.90.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dexie": "^4.4.2",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "lucide-react": "^0.575.0",
    "prettier": "^3.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.76.0",
    "size-limit": "^12.1.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.6",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19"
  }
}
